# Database
DATABASE_URL="file:./dev.db"
# For production PostgreSQL (Neon, Supabase, etc.):
# DATABASE_URL="postgresql://user:password@host:5432/digitalcard?sslmode=require"

# Auth — generate with: openssl rand -base64 32
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Apple Wallet (optional — add when you have Apple Developer account)
APPLE_PASS_TYPE_ID="pass.com.yourapp.businesscard"
APPLE_TEAM_ID="YOURTEAMID"
# APPLE_CERT_BASE64= (base64 encoded .p12 certificate)
# APPLE_CERT_PASSWORD=
# APPLE_WWDR_CERT_BASE64= (base64 encoded Apple WWDR G4 cert)

# Google Wallet (optional — add when you have Google Cloud project)
GOOGLE_WALLET_ISSUER_ID="your-issuer-id"
# GOOGLE_SERVICE_ACCOUNT_EMAIL=
# GOOGLE_SERVICE_ACCOUNT_KEY= (base64 encoded private key JSON)
